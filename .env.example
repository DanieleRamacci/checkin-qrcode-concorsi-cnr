# Application
APP_ENV=production
APP_VERSION=dev
APP_BUILD_TIME=
DEBUG=0
FLASK_ENV=production
SECRET_KEY=replace-with-a-long-random-secret

# BASE_URL e' l'endpoint dell'API esterna Selezioni Online/JConon (candidati,
# commissioni, RDP), NON l'URL di questa applicazione. Non impostarlo al
# dominio dove gira l'app: quello va solo in OIDC_REDIRECT_URI.
BASE_URL=https://selezionionline.example.cnr.it

# OIDC
OIDC_CLIENT_ID=replace-with-client-id
OIDC_CLIENT_SECRET=replace-with-client-secret
OIDC_REDIRECT_URI=https://checkin.example.cnr.it/oidc-callback
OIDC_AUTH_URL=https://idp.example.cnr.it/realms/cnr/protocol/openid-connect/auth
OIDC_TOKEN_URL=https://idp.example.cnr.it/realms/cnr/protocol/openid-connect/token
OIDC_USERINFO_URL=https://idp.example.cnr.it/realms/cnr/protocol/openid-connect/userinfo
OIDC_ISSUER=https://idp.example.cnr.it/realms/cnr
OIDC_AUDIENCE=replace-with-client-id
OIDC_JWKS_URL=https://idp.example.cnr.it/realms/cnr/protocol/openid-connect/certs
OIDC_ALLOWED_ALGORITHM=RS256

# PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=checkin
POSTGRES_USER=checkin
POSTGRES_PASSWORD=replace-with-database-password

# Server-side sessions
SESSION_TYPE=redis
REDIS_PASSWORD=replace-with-redis-password
REDIS_URL=redis://:replace-with-redis-password@redis:6379/0
COOKIE_SECURE=1

# Mail
SMTP_SERVER=smtp.example.cnr.it
SMTP_PORT=587
SMTP_STARTTLS=1
MAIL_SENDER=checkin@example.cnr.it
ESPERTO_EMAIL=

# Authorization bootstrap
BOOTSTRAP_ADMIN_EMAILS=

# Generated files
FILES_BASE_DIR=/app/files_liste
